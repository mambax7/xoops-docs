---
// src/pages/index.astro
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'XOOPS Documentation' }}>
  <div class="portal-hero">
    <img src="/xoops-logo.svg" alt="XOOPS CMS" class="portal-logo" />
    <h1>XOOPS Documentation</h1>
    <p class="portal-tagline">
      The world's best PHP CMS — documented properly.
    </p>
  </div>

  <div class="portal-grid">
    <a href="/en/quick-start/" class="portal-card card-new">
      <span class="card-icon">🚀</span>
      <div>
        <strong>New to XOOPS?</strong>
        <span>Quick Start →</span>
      </div>
    </a>

    <a href="/en/module-guide/" class="portal-card card-module">
      <span class="card-icon">🧩</span>
      <div>
        <strong>Module Developer?</strong>
        <span>Module Guide →</span>
      </div>
    </a>

    <a href="/en/theme-guide/" class="portal-card card-theme">
      <span class="card-icon">🎨</span>
      <div>
        <strong>Theme Developer?</strong>
        <span>Theme Guide →</span>
      </div>
    </a>

    <a href="/en/migration/" class="portal-card card-upgrade">
      <span class="card-icon">⬆️</span>
      <div>
        <strong>Upgrading?</strong>
        <span>Migration Guide →</span>
      </div>
    </a>
  </div>

  <div class="portal-versions">
    <h2>Documentation Versions</h2>
    <div class="version-links">
      <a href="/2.7/" class="version-badge active">XOOPS 2.7.x</a>
      <a href="/4.x/" class="version-badge">XOOPS 4.x</a>
    </div>
  </div>
</StarlightPage>

<style>
  .portal-hero {
    text-align: center;
    padding: 3rem 1rem 2rem;
  }
  .portal-logo {
    height: 80px;
    margin-bottom: 1rem;
  }
  .portal-tagline {
    color: var(--sl-color-gray-3);
    font-size: 1.1rem;
  }
  .portal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }
  .portal-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.1s;
    background: var(--sl-color-black);
  }
  .portal-card:hover {
    border-color: var(--sl-color-accent);
    transform: translateY(-2px);
  }
  .portal-card strong { display: block; color: var(--sl-color-white); }
  .portal-card span { color: var(--sl-color-accent); font-size: 0.9rem; }
  .card-icon { font-size: 2rem; }
  .portal-versions { margin-top: 3rem; }
  .version-links { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1rem; }
  .version-badge {
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    border: 1px solid var(--sl-color-accent);
    color: var(--sl-color-accent);
    text-decoration: none;
    font-size: 0.9rem;
    transition: background 0.2s;
  }
  .version-badge.active,
  .version-badge:hover {
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
  }
</style>