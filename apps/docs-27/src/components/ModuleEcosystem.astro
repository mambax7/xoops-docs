---
// src/components/ModuleEcosystem.astro
import { fetchModulesWithReleases, fetchModules } from '../lib/github-modules';

// These run at BUILD TIME — generates static HTML
const recentlyUpdated = await fetchModulesWithReleases(10);
const allModules = await fetchModules();

function timeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const days = Math.floor(diff / 86400000);
  if (days === 0) return 'today';
  if (days === 1) return 'yesterday';
  if (days < 30) return `${days} days ago`;
  if (days < 365) return `${Math.floor(days / 30)} months ago`;
  return `${Math.floor(days / 365)} years ago`;
}

// Extract highlights from release body (first line or key tags)
function parseReleaseHighlight(body: string): string {
  if (!body) return '';
  const lines = body.split('\n').filter(l => l.trim());
  // Look for PHP 8.x, Bootstrap, PSR mentions
  const highlights = lines
    .flatMap(l => l.match(/PHP \d+\.\d+|Bootstrap \d|PSR-\d+|XOOPS \d\.\d/g) ?? [])
    .slice(0, 3);
  return highlights.join(' · ');
}
---

<section class="module-ecosystem">
  <h2>Module Ecosystem</h2>
  <p class="ecosystem-stats">
    <strong>{allModules.length}</strong> modules available ·
    Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
  </p>

  <!-- Recently Updated — proves the ecosystem is alive -->
  <h3>Recently Updated</h3>
  <ul class="module-feed">
    {recentlyUpdated.map(mod => (
      <li class="module-item">
        <a href={mod.html_url} target="_blank" rel="noopener">
          <strong>{mod.name}</strong>
          <span class="module-version">{mod.latestRelease?.tag_name}</span>
        </a>
        <span class="module-highlight">
          {mod.latestRelease ? parseReleaseHighlight(mod.latestRelease.body) : ''}
        </span>
        <span class="module-age">{timeAgo(mod.latestRelease!.published_at)}</span>
      </li>
    ))}
  </ul>

  <!-- Full Module Table (searchable via browser find) -->
  <h3>All Modules ({allModules.length})</h3>
  <div class="module-grid">
    {allModules.map(mod => (
      <a href={mod.html_url} class="module-card" target="_blank" rel="noopener">
        <strong>{mod.name}</strong>
        {mod.description && <p>{mod.description}</p>}
        <span class="module-stars">★ {mod.stargazers_count}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .module-ecosystem { margin: 2rem 0; }
  .ecosystem-stats { color: var(--sl-color-gray-3); }

  .module-feed { list-style: none; padding: 0; }
  .module-item {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 0.5rem 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--sl-color-gray-6);
    align-items: center;
  }
  .module-version {
    font-family: var(--sl-font-mono);
    font-size: 0.8rem;
    color: var(--sl-color-accent);
    margin-left: 0.5rem;
  }
  .module-highlight { font-size: 0.8rem; color: var(--sl-color-gray-3); }
  .module-age { font-size: 0.8rem; color: var(--sl-color-gray-4); white-space: nowrap; }

  .module-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .module-card {
    padding: 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .module-card:hover { border-color: var(--sl-color-accent); }
  .module-card strong { display: block; color: var(--sl-color-white); }
  .module-card p { font-size: 0.8rem; color: var(--sl-color-gray-3); margin: 0.25rem 0; }
  .module-stars { font-size: 0.75rem; color: var(--sl-color-gray-4); }
</style>
